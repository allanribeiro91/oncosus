# Copie para .env nesta pasta (backend/rag) ou na raiz do repositório oncosus-novo.
# Modelo Ollama que você criou (ex.: Modelfile com llama3.2:1b + num_gpu 0)
ONCOSUS_OLLAMA_MODEL=oncosus-llm

# Opcional: menos RAM no prompt + KV cache
# ONCOSUS_OLLAMA_NUM_CTX=2048
# ONCOSUS_TOP_K=4
# ONCOSUS_FINAL_K=2
